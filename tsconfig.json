{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "es2022",
    "module": "node16",
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "types": ["node"]
  },
  "include": ["db/**/*.js"],
  "exclude": ["node_modules", "db/migrations/migrations/**/*.js", "utils/**"]
}
